{
	"name": "@lumen-media/module-sdk",
	"version": "0.3.1",
	"description": "Public contract for building Lumen modules",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./testing": {
			"types": "./dist/testing.d.ts",
			"import": "./dist/testing.js"
		},
		"./hooks": {
			"types": "./dist/hooks.d.ts",
			"import": "./dist/hooks.js"
		},
		"./ui": {
			"types": "./dist/ui.d.ts",
			"import": "./dist/ui.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"peerDependencies": {
		"react": ">=19",
		"react-dom": ">=19"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": false
		},
		"react-dom": {
			"optional": false
		}
	},
	"devDependencies": {
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Lumen-media/module-sdk.git",
		"directory": "packages/module-sdk"
	},
	"keywords": [
		"lumen",
		"module",
		"plugin",
		"sdk"
	]
}
