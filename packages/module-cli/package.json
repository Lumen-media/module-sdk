{
	"name": "@lumen/module-cli",
	"version": "0.0.0",
	"description": "Command-line tool for building Lumen modules",
	"type": "module",
	"bin": {
		"lumen-module": "./dist/lumen-module.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
