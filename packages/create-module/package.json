{
	"name": "@lumen-media/create-module",
	"version": "0.1.0",
	"private": true,
	"description": "Scaffolder for new Lumen modules",
	"type": "module",
	"bin": {
		"create-module": "./dist/cli.js"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist",
		"dist/templates"
	],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"devDependencies": {
		"@types/node": "^22.10.0"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Lumen-media/module-sdk.git",
		"directory": "packages/create-module"
	},
	"keywords": [
		"lumen",
		"module",
		"create",
		"scaffolder",
		"sdk"
	]
}
