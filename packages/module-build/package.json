{
	"name": "@lumen-media/module-build",
	"version": "0.0.0",
	"private": true,
	"description": "Vite plugin for building Lumen modules",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@lumen-media/module-sdk": "workspace:*",
		"ajv": "^8.17.1",
		"ajv-formats": "^3.0.1"
	},
	"peerDependencies": {
		"vite": ">=5"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"vite": "^7.0.0"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/Lumen-media/module-sdk.git",
		"directory": "packages/module-build"
	},
	"keywords": [
		"lumen",
		"module",
		"vite-plugin",
		"sdk"
	]
}
