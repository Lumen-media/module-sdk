{
	"name": "module-sdk",
	"version": "0.0.0",
	"private": true,
	"description": "Lumen module SDK monorepo",
	"type": "module",
	"scripts": {
		"build": "pnpm -r build",
		"dev": "pnpm -r --parallel dev",
		"typecheck": "pnpm -r typecheck",
		"test": "pnpm -r test",
		"lint": "biome check .",
		"format": "biome format --write .",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "pnpm build && changeset publish"
	},
	"license": "MIT",
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "^11.2.2",
			"onFail": "download"
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@changesets/cli": "^2.31.0",
		"tsup": "^8.5.1",
		"typescript": "^5.9.3",
		"vitest": "^4.1.7"
	}
}
